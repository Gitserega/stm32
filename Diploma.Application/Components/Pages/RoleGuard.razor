@* Вставляй этот компонент в начало любой страницы требующей роль.
   Пример: <RoleGuard AllowedRole="operator" />
   При несоответствии роли — редирект на /login или /403 *@

@rendermode InteractiveServer
@using Diploma.Application.Services
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

@code {
    /// <summary>Роль которой разрешён доступ: "operator" или "admin"</summary>
    [Parameter, EditorRequired] public string AllowedRole { get; set; } = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var token = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "auth_token");

        // Нет токена — на логин
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("/login", replace: true);
            return;
        }

        // Проверяем роль из UserState (уже заполнен MainLayout)
        // Если UserState ещё пуст — проверяем напрямую через JWT
        var role = UserState.Role;
        if (string.IsNullOrEmpty(role))
            role = ExtractRoleFromToken(token);

        var allowed = role.Equals(AllowedRole, StringComparison.OrdinalIgnoreCase);
       

        if (!allowed)
            Navigation.NavigateTo("/forbidden", replace: true);
    }

    private static string ExtractRoleFromToken(string token)
    {
        try
        {
            var parts = token.Split('.');
            if (parts.Length != 3) return "";

            var payload = parts[1].Replace('-', '+').Replace('_', '/');
            switch (payload.Length % 4)
            {
                case 2: payload += "=="; break;
                case 3: payload += "=";  break;
            }

            var json   = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(payload));
            var claims = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, System.Text.Json.JsonElement>>(json);

            const string roleKey = "http://schemas.microsoft.com/ws/2008/06/identity/claims/role";
            if (claims != null && claims.TryGetValue(roleKey, out var el))
                return el.GetString() ?? "";
        }
        catch { }
        return "";
    }
}
