@using Diploma.DTO.Config
@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Новое устройство</MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_name" Label="Название устройства" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_rms" Label="RMS (опционально)" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_crest" Label="Crest Factor (опционально)" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_bearing" Label="Bearing (опционально)" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_gear" Label="Gear (опционально)" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Отмена</MudButton>
        <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="Save" Disabled="@string.IsNullOrWhiteSpace(_name)">Создать</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private string _name = "";
    private double? _rms;
    private double? _crest;
    private double? _bearing;
    private double? _gear;

    private void Save()
    {
        var request = new CreateDeviceRequest
        {
            Name = _name,
            Rms = _rms,
            Crest = _crest,
            Bearing = _bearing,
            Gear = _gear
        };
        MudDialog.Close(DialogResult.Ok(request));
    }

    private void Cancel() => MudDialog.Cancel();
}